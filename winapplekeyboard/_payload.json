[{"data":1,"prerenderedAt":115},["ShallowReactive",2],{"$PO0ZRGd7KQ":3},{"id":4,"title":5,"body":6,"description":90,"extension":96,"meta":97,"navigation":110,"path":111,"seo":112,"stem":113,"__hash__":114},"content/把蘋果無線巧拼鍵盤 apple magic keyboard 更改成 windows配置!!.md","把蘋果無線巧拼鍵盤 Apple Magic Keyboard 更改成 Windows配置!!",{"type":7,"value":8,"toc":89},"minimal",[9,13,17,20,27,30,40,43,46,54,62,71,80,83,86],[10,11,12],"h3",{"id":12},"介紹",[14,15,16],"p",{},"最近入手了蘋果的巧拼鍵盤，結果發現他的鍵盤位置的左下角是 fn 鍵而不是 ctrl，讓我覺得跟其他鍵盤比巧來用得太卡了。",[14,18,19],{},"畢竟工程師最常用的就是 ctrl + 各種按鈕了",[14,21,22],{},[23,24],"img",{"alt":25,"src":26},"test","https://store.storeimages.cdn-apple.com/8756/as-images.apple.com/is/MLA22CH?wid=572&hei=572&fmt=jpeg&qlt=95&op_usm=0.5,0.5&.v=1496100487492",[14,28,29],{},"那我最主要想要的功能就是把 ctrl 鍵換成在鍵盤的左下角這樣跟原本的鍵盤操作才會一致",[14,31,32,33],{},"於是我 google 了一下還真的給我找到有人做了轉換的工具 ",[34,35,39],"a",{"href":36,"rel":37},"https://github.com/samartzidis/WinAppleKey",[38],"nofollow","WinAppleKey",[14,41,42],{},"真的是太強了(跪)，順手就給了一顆 star",[10,44,45],{"id":45},"安裝",[14,47,48,49],{},"其實在 github 裡面的說明已經很清楚了，第一步就是先下載這個 ",[34,50,53],{"href":51,"rel":52},"https://github.com/samartzidis/WinAppleKey/releases",[38],"軟體",[14,55,56,57,61],{},"第二步你要在 cmd 裡面下 ",[58,59,60],"code",{},"bcdedit.exe -set TESTSIGNING ON"," 這串指令，",[63,64,66,70],"h4",{"id":65},"注意-window-的話請用系統管理者打開-cmd-不然權限不夠",[67,68,69],"strong",{},"注意"," window 的話請用系統管理者打開 cmd 不然權限不夠",[63,72,74,76,77,79],{"id":73},"注意-開啟-bcdeditexe-set-testsigning-on-是有風險的請在使用前先評估自己有沒有辦法承擔風險",[67,75,69],{}," 開啟 ",[58,78,60],{}," 是有風險的，請在使用前先評估自己有沒有辦法承擔風險",[14,81,82],{},"第三步 重開機",[14,84,85],{},"第四步 安裝剛剛下載的 Setup.msi",[14,87,88],{},"接著應該就完成了(灑花)",{"title":90,"searchDepth":91,"depth":91,"links":92},"",2,[93,95],{"id":12,"depth":94,"text":12},3,{"id":45,"depth":94,"text":45},"md",{"createdAt":98,"url":99,"tags":100,"excerpt":102},"2019-09-26 23:26:25","winapplekeyboard",[101],"鍵盤",{"type":7,"value":103},[104,106,108],[10,105,12],{"id":12},[14,107,16],{},[14,109,19],{},true,"/apple-magic-keyboard-windows!!",{"title":5,"description":90},"把蘋果無線巧拼鍵盤 apple magic keyboard 更改成 windows配置!!","r7BglgoLNEIgkmbnvVA3-O1QNxNIzrmw4qu2-EjtXQY",1742644319681]